# AI EMPLOYEE SYSTEM - ENVIRONMENT VARIABLES
# Copy this to .env and fill in your values
# NEVER commit .env to Git

# ===== BRONZE TIER =====
ANTHROPIC_API_KEY=sk-ant-...your-api-key...
VAULT_PATH=d:\DocuBook-Chatbot folder\Personal AI Employee\AI_Employee_System\Vault

# ===== SILVER TIER =====
# Gmail
GMAIL_ADDRESS=your.email@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
NOTIFICATION_EMAIL=your.email@gmail.com

# WhatsApp
WHATSAPP_PHONE_ID=your_phone_number_id
WHATSAPP_ACCESS_TOKEN=your_meta_api_token

# LinkedIn
LINKEDIN_ACCESS_TOKEN=your_linkedin_token

# Twitter
TWITTER_API_KEY=your_api_key
TWITTER_API_SECRET=your_api_secret
TWITTER_BEARER_TOKEN=your_bearer_token

# ===== GOLD TIER =====
# Odoo
ODOO_URL=http://localhost:8069
ODOO_DATABASE=odoo
ODOO_USERNAME=admin
ODOO_PASSWORD=admin

# Facebook
FACEBOOK_ACCESS_TOKEN=your_token
FACEBOOK_PAGE_ID=your_page_id

# Instagram
INSTAGRAM_ACCESS_TOKEN=your_token
INSTAGRAM_ACCOUNT_ID=your_account_id

# ===== PLATINUM TIER =====
# Cloud Setup (Google Cloud Compute Engine or Oracle Cloud)
CLOUD_VM_IP=your_cloud_vm_ip
CLOUD_VM_SSH_KEY=path/to/private/key
GIT_REPO=git@github.com:your-username/ai-employee-vault.git

# Deployment
ENVIRONMENT=development  # or production
DEBUG=True
