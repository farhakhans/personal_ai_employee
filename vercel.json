{
  "version": 2,
  "builds": [
    {
      "src": "api_routes.py",
      "use": "@vercel/python",
      "config": {
        "runtime": "python3.9"
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "api_routes.py"
    }
  ],
  "env": {
    "VERCEL": "1",
    "VAULT_PATH": "/tmp/vault",
    "PYTHONPATH": "."
  },
  "outputDirectory": "tmp"
}
