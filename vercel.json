{
  "version": 2,
  "builds": [
    {
      "src": "app.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "app.py"
    }
  ],
  "env": {
    "SECRET_KEY": "@secret-key",
    "ANTHROPIC_API_KEY": "@anthropic-key",
    "VAULT_PATH": "/tmp/vault"
  },
  "outputDirectory": "public"
}
